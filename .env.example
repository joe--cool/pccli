# Copy this file to .env for project-local config, or to ~/.pccli/.env
# for user-level config shared across directories.

PCCLI_CLIENT_ID=
PCCLI_CLIENT_SECRET=

# Optional: use local mock responses for demos, tests, and VHS recordings.
PCCLI_MOCK=false
PCCLI_MOCK_FIXTURE=testdata/mocks/services-library.json

# Optional defaults.
PCCLI_BASE_URL=https://api.planningcenteronline.com
PCCLI_UPLOAD_URL=https://upload.planningcenteronline.com
PCCLI_TIMEOUT=30s
PCCLI_COLOR=auto
